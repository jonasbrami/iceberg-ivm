server:
  port: 8000
  config_reload_interval_seconds: 30

# Trino connection URL, user, and password are read from environment
# variables — *never* from this file. No defaults; the orchestrator
# refuses to start without them.
#
#   TRINO_URL       e.g. "http://trino:8080" (required)
#   TRINO_USER      e.g. "orchestrator"       (required)
#   TRINO_PASSWORD  BasicAuth password        (optional — omit for anonymous)
#
# Only `catalog` and `schema` (the per-deployment Trino catalog + target
# schema — not secrets) live in this file.
trino:
  catalog: iceberg
  schema: analytics
